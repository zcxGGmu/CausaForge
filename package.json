{
  "name": "causaforge-agent",
  "version": "4.17.0",
  "description": "Evidence-chain workflow harness for OpenCode-first patch delivery",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "workspaces": [
    "packages/causaforge-core",
    "packages/causaforge-opencode"
  ],
  "bin": {
    "causaforge": "bin/causaforge.js",
    "causaforge-agent": "bin/causaforge.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "ROADMAP.md",
    "LICENSE.md",
    "packages/causaforge-core",
    "packages/causaforge-opencode"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./opencode": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run script/build.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json && bun run --cwd packages/causaforge-core typecheck && bun run --cwd packages/causaforge-opencode typecheck",
    "test": "bun test packages/causaforge-core/src packages/causaforge-opencode/src"
  },
  "keywords": [
    "causaforge",
    "opencode",
    "workflow",
    "evidence-chain",
    "ai",
    "llm"
  ],
  "author": "zcxGGmu",
  "license": "SUL-1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zcxGGmu/CausaForge.git"
  },
  "bugs": {
    "url": "https://github.com/zcxGGmu/CausaForge/issues"
  },
  "homepage": "https://github.com/zcxGGmu/CausaForge#readme",
  "dependencies": {
    "@opencode-ai/plugin": "1.15.13",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@causaforge/core": "workspace:*",
    "@causaforge/opencode-adapter": "workspace:*",
    "@typescript/native-preview": "7.0.0-dev.20260518.1",
    "bun-types": "1.3.14",
    "typescript": "^6.0.3"
  }
}
